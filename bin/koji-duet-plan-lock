#!/usr/bin/env python3
"""koji-duet-plan-lock: lock a /duet-plan consensus plan to $DOCS_PATH/plans/.

Strips the trailing VERDICT line from the plan body, prepends a metadata
header, resolves filename conflicts (appends -2, -3, ... if needed), and
writes to $DOCS_PATH/plans/<slug>.md.

Slugs are derived from the topic (kebab-case, truncated to 60 chars).
Override with --slug if the auto-derived one is ugly.
"""
import argparse
import re
import sys
from datetime import datetime
from pathlib import Path


def slug_from_topic(topic: str, max_len: int = 60) -> str:
    s = topic.lower().strip()
    s = re.sub(r"[^a-z0-9]+", "-", s)
    s = s.strip("-")
    if len(s) > max_len:
        s = s[:max_len].rstrip("-")
    return s or "untitled-plan"


def resolve_conflict(plans_dir: Path, slug: str) -> str:
    base = plans_dir / f"{slug}.md"
    if not base.exists():
        return slug
    n = 2
    while (plans_dir / f"{slug}-{n}.md").exists():
        n += 1
    return f"{slug}-{n}"


def strip_verdict_line(content: str) -> str:
    """Remove the trailing VERDICT: line(s) so the locked plan body is clean."""
    lines = content.rstrip("\n").splitlines()
    while lines and re.match(r"^\s*VERDICT\s*:", lines[-1], re.IGNORECASE):
        lines.pop()
    while lines and lines[-1].strip() == "":
        lines.pop()
    return "\n".join(lines) + "\n"


def lock_plan(
    plan_content: str,
    topic: str,
    rounds: int,
    claude_verdict: str,
    codex_verdict: str,
    out_path: Path,
) -> None:
    body = strip_verdict_line(plan_content)
    date = datetime.now().strftime("%Y-%m-%d")
    # YAML frontmatter for koji-plans-research; goes above the HTML comment
    # so human-readable metadata shows first. Pre-YAML plans get `inferred`.
    yaml_fm = (
        "---\n"
        "status: pending\n"
        f"origin-session: {date}\n"
        "target: implementation\n"
        "---\n\n"
    )
    header = (
        "<!--\n"
        "locked plan from /duet-plan\n"
        f"topic: {topic}\n"
        f"date: {date}\n"
        f"rounds: {rounds}\n"
        f"claude_verdict: {claude_verdict}\n"
        f"codex_verdict: {codex_verdict}\n"
        "-->\n\n"
    )
    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_text(yaml_fm + header + body)


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--plan", required=True, help="path to final Claude plan file")
    ap.add_argument("--topic", required=True)
    ap.add_argument("--rounds", required=True, type=int)
    ap.add_argument("--claude-verdict", default="AGREE")
    ap.add_argument("--codex-verdict", default="AGREE")
    ap.add_argument(
        "--plans-dir",
        required=True,
        help="absolute path to $DOCS_PATH/plans (will be created)",
    )
    ap.add_argument(
        "--slug",
        default="",
        help="override auto-derived slug (kebab-case recommended)",
    )
    args = ap.parse_args()

    plan_file = Path(args.plan)
    if not plan_file.is_file():
        print(f"ERROR: plan file not found: {plan_file}", file=sys.stderr)
        return 1

    plans_dir = Path(args.plans_dir)
    slug = args.slug.strip() or slug_from_topic(args.topic)
    final_slug = resolve_conflict(plans_dir, slug)
    out_path = plans_dir / f"{final_slug}.md"

    plan_content = plan_file.read_text()
    lock_plan(
        plan_content,
        args.topic,
        args.rounds,
        args.claude_verdict,
        args.codex_verdict,
        out_path,
    )
    print(str(out_path))
    return 0


if __name__ == "__main__":
    sys.exit(main())
