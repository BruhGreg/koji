#!/usr/bin/env bash
# koji-detect — detect project config and emit shell variables
#
# Usage: source <(~/.claude/skills/koji/bin/koji-detect)
#
# Reads .koji.yaml from project root, falls back to ~/.koji/config.yaml,
# then to hardcoded defaults. Outputs shell variable assignments.
set -euo pipefail

KOJI_DIR="${KOJI_STATE_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/koji}"
KOJI_SKILLS="$HOME/.claude/skills/koji"

# --- Detect project root ---
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"

# --- YAML reader (simple key extraction, no external deps) ---
_yaml_get() {
  local file="$1" key="$2"
  [ -f "$file" ] || return 0

  local parent="${key%%.*}"
  local child="${key#*.}"

  if [ "$parent" = "$child" ]; then
    grep -E "^${key}:" "$file" 2>/dev/null | tail -1 | sed 's/^[^:]*:[[:space:]]*//' | sed 's/[[:space:]]*$//' | sed -e 's/^"\(.*\)"$/\1/' -e "s/^'\(.*\)'\$/\1/" || true
  else
    awk -v parent="$parent" -v child="$child" '
      $0 ~ "^"parent":" { in_block=1; next }
      in_block && /^[^ ]/ { in_block=0 }
      in_block && $0 ~ "^[[:space:]]+"child":" {
        sub(/^[[:space:]]+[^:]+:[[:space:]]*/, "")
        sub(/[[:space:]]*$/, "")
        # Strip surrounding YAML quotes
        if (substr($0,1,1) == "\"" && substr($0,length($0),1) == "\"") $0 = substr($0,2,length($0)-2)
        if (substr($0,1,1) == "\047" && substr($0,length($0),1) == "\047") $0 = substr($0,2,length($0)-2)
        print
        exit
      }
    ' "$file" 2>/dev/null || true
  fi
}

# --- YAML list reader ---
_yaml_list() {
  local file="$1" key="$2"
  [ -f "$file" ] || return 0
  awk -v key="$key" '
    $0 ~ "^"key":" { in_list=1; next }
    in_list && /^[^ ]/ { exit }
    in_list && /^[[:space:]]*-[[:space:]]/ {
      sub(/^[[:space:]]*-[[:space:]]*/, "")
      sub(/[[:space:]]*$/, "")
      printf "%s ", $0
    }
  ' "$file" 2>/dev/null || true
}

# --- Config files (project takes priority) ---
PROJECT_CONFIG="$PROJECT_ROOT/.koji.yaml"
GLOBAL_CONFIG="$KOJI_DIR/config.yaml"

# --- Read with cascade: project -> global -> default ---
_resolve() {
  local key="$1" default="$2"
  local val
  val="$(_yaml_get "$PROJECT_CONFIG" "$key")"
  [ -n "$val" ] && { echo "$val"; return; }
  val="$(_yaml_get "$GLOBAL_CONFIG" "$key")"
  [ -n "$val" ] && { echo "$val"; return; }
  echo "$default"
}

# --- Emit variables ---
# Safe emission: use printf %q so values are escaped for safe sourcing.
# Without this, a path or config value containing $(), backticks, or quotes
# would execute as code when the caller does `eval "$(koji-detect)"`.
_emit() { printf '%s=%q\n' "$1" "$2"; }

_emit PROJECT_ROOT "$PROJECT_ROOT"
_emit PROJECT_NAME "$PROJECT_NAME"
_emit KOJI_SKILLS "$KOJI_SKILLS"

DOCS_DIR="$(_resolve "docs_dir" "docs")"
_emit DOCS_DIR "$DOCS_DIR"
_emit DOCS_PATH "$PROJECT_ROOT/$DOCS_DIR"

_emit TEMPLATE "$(_resolve "template" "default")"

_emit ARCHIVE_STRATEGY "$(_resolve "archive.strategy" "numbered")"
_emit ARCHIVE_THRESHOLD "$(_resolve "archive.threshold" "5")"
_emit ARCHIVE_KEEP "$(_resolve "archive.keep" "1")"
_emit ARCHIVE_DIR "$(_resolve "archive.dir" "sessions")"

_emit SESSION_FILE "agent-session.md"
_emit HANDOFF_FILE "AI_HANDOFF.md"
_emit LESSONS_FILE "lessons.md"

_emit WRAP_STARTER "$(_resolve "wrap.starter_prompt" "true")"

# Commit strategy preference (persisted via koji-config)
COMMIT_STRATEGY="$("$KOJI_SKILLS/bin/koji-config" get commit_strategy 2>/dev/null || true)"
_emit COMMIT_STRATEGY "$COMMIT_STRATEGY"

# Agents list
AGENTS="$(_yaml_list "$PROJECT_CONFIG" "agents")"
[ -z "$AGENTS" ] && AGENTS="$(_yaml_list "$GLOBAL_CONFIG" "agents")"
[ -z "$AGENTS" ] && AGENTS="Claude"
_emit AGENTS "$AGENTS"

# Global session-state path (per-project keyed). Lives OUTSIDE the repo so it
# can't be committed by accident. /kick-off writes "start" with the session's
# starting git rev; /wrap reads it and removes it on completion.
KOJI_STATE_DIR="${KOJI_STATE_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/koji}"
# Hash the project root for SESSION_DIR uniqueness. md5 is macOS-native;
# md5sum is GNU coreutils; shasum is in macOS + most Linux (perl-based);
# cksum is POSIX. Cascade through them so the hash is never empty —
# an empty hash would let two projects with the same basename collide on
# the same SESSION_DIR (Alpine/busybox repro: no md5 AND no md5sum).
_SESSION_HASH=$(printf '%s' "$PROJECT_ROOT" | (md5 2>/dev/null || md5sum 2>/dev/null | cut -d' ' -f1) | head -c 8)
[ -n "$_SESSION_HASH" ] || _SESSION_HASH=$(printf '%s' "$PROJECT_ROOT" | shasum 2>/dev/null | cut -d' ' -f1 | head -c 8)
[ -n "$_SESSION_HASH" ] || _SESSION_HASH=$(printf '%s' "$PROJECT_ROOT" | cksum 2>/dev/null | cut -d' ' -f1)
[ -n "$_SESSION_HASH" ] || _SESSION_HASH="nohash"
SESSION_DIR="$KOJI_STATE_DIR/sessions/$(basename "$PROJECT_ROOT")-$_SESSION_HASH"
SESSION_START_FILE="$SESSION_DIR/start"
_emit KOJI_STATE_DIR "$KOJI_STATE_DIR"
_emit SESSION_HASH "$_SESSION_HASH"
_emit SESSION_DIR "$SESSION_DIR"
_emit SESSION_START_FILE "$SESSION_START_FILE"

# TODO config — resolve file name with auto-detection cascade:
# 1. Explicit .koji.yaml config (todo.file)
# 2. Auto-detect: check project root for TODO.md or TODOS.md
# 3. Auto-detect: check docs dir (legacy location)
# 4. Default: TODO.md at project root
TODO_FILE_CFG="$(_resolve "todo.file" "")"
if [ -n "$TODO_FILE_CFG" ]; then
  TODO_FILE="$TODO_FILE_CFG"
elif [ -f "$PROJECT_ROOT/TODO.md" ]; then
  TODO_FILE="TODO.md"
elif [ -f "$PROJECT_ROOT/TODOS.md" ]; then
  TODO_FILE="TODOS.md"
elif [ -f "$PROJECT_ROOT/$DOCS_DIR/TODO.md" ]; then
  TODO_FILE="TODO.md"
elif [ -f "$PROJECT_ROOT/$DOCS_DIR/TODOS.md" ]; then
  TODO_FILE="TODOS.md"
else
  TODO_FILE="TODO.md"
fi
TODO_COMPLETED="$(_resolve "todo.completed" "inline")"

# Resolve TODO path — project root is canonical, docs dir is legacy
if [ -f "$PROJECT_ROOT/$TODO_FILE" ]; then
  TODO_PATH="$PROJECT_ROOT/$TODO_FILE"
elif [ -f "$PROJECT_ROOT/$DOCS_DIR/$TODO_FILE" ]; then
  TODO_PATH="$PROJECT_ROOT/$DOCS_DIR/$TODO_FILE"
  TODO_NEEDS_MIGRATION=true
else
  # Not found yet — default to project root (will be created there by wrap)
  TODO_PATH="$PROJECT_ROOT/$TODO_FILE"
fi

_emit TODO_FILE "$TODO_FILE"
_emit TODO_PATH "$TODO_PATH"
_emit TODO_COMPLETED "$TODO_COMPLETED"
_emit TODO_NEEDS_MIGRATION "${TODO_NEEDS_MIGRATION:-false}"

# State checks
[ -f "$PROJECT_CONFIG" ] && echo "HAS_PROJECT_CONFIG=true" || echo "HAS_PROJECT_CONFIG=false"
[ -d "$PROJECT_ROOT/$DOCS_DIR" ] && echo "HAS_DOCS=true" || echo "HAS_DOCS=false"
[ -f "$PROJECT_ROOT/$DOCS_DIR/agent-session.md" ] && echo "HAS_SESSION_LOG=true" || echo "HAS_SESSION_LOG=false"
[ -f "$PROJECT_ROOT/$DOCS_DIR/AI_HANDOFF.md" ] && echo "HAS_HANDOFF=true" || echo "HAS_HANDOFF=false"
[ -f "$PROJECT_ROOT/$DOCS_DIR/lessons.md" ] && echo "HAS_LESSONS=true" || echo "HAS_LESSONS=false"
[ -f "$TODO_PATH" ] && echo "HAS_TODO=true" || echo "HAS_TODO=false"
