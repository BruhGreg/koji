#!/usr/bin/env python3
"""koji-duet-synthesize: merge Claude + codex findings into a verdict JSON.

Inputs: two JSON files (one per reviewer), each a list of finding objects
matching the schema in references/reviewer-prompt.md.

Optional second-pass inputs:
  --claude-cross  Claude's verdicts on codex's solo findings (cross-review)
  --codex-cross   codex's verdicts on Claude's solo findings (cross-review)
  --cross-review-done  Mark the verdict as final (no more cross-review passes)

Output: a single verdict JSON written to --out, with the schema in
references/verdict-format.md.

The exit code matches the verdict's exit_code field (0/1/2). This lets
callers (e.g., /duet-impl) gate on the process exit directly.

Cross-review logic:
  * First-pass: writes cross_review_required=true if ANY reviewer-exclusive
    finding has severity >= medium (lows skip — not a style committee).
  * Second-pass (--*-cross + --cross-review-done): reprocesses solo findings
    using the other reviewer's labels. AGREE-HIGH/MEDIUM/LOW promote to
    consensus at that severity; DISAGREE / NEEDS-MORE-CONTEXT stay solo.
  * /duet-review Steps 5/6 must refuse if cross_review_required && !done.
"""
import argparse
import json
import sys
from pathlib import Path

SEV_RANK = {"high": 3, "medium": 2, "low": 1}

# Line-fuzzing window: findings within ±LINE_WINDOW lines + same file +
# same category family are treated as one. Reviewers naturally drift 1-2
# lines and pick related-but-different categories for the same bug.
LINE_WINDOW = 5

# Category families — collapse reviewer-naming variance (e.g., one says
# "correctness", another "data-loss") without merging unrelated bugs.
CATEGORY_FAMILY = {
    "correctness": "correctness",
    "data-loss": "correctness",
    "error-handling": "correctness",
    "race": "correctness",
    "security": "security",
    "perf": "perf",
    "types": "types",
    "deps": "deps",
    "deadcode": "deadcode",
    "style": "style",
    "other": "other",
}


def family(cat: str) -> str:
    return CATEGORY_FAMILY.get(cat, "other")


def _line(f: dict) -> int:
    try:
        return int(f.get("line", 0))
    except (TypeError, ValueError):
        return 0


def find_consensus(claude: list, codex: list) -> tuple:
    """Greedy match: each Claude finding pairs with nearest unmatched Codex
    finding (same file, same category family, within LINE_WINDOW lines).

    Returns (consensus_pairs, claude_used_idxs, codex_used_idxs).
    """
    consensus_pairs = []
    claude_used = set()
    codex_used = set()
    for ci, cf in enumerate(claude):
        cf_file = cf.get("file", "")
        cf_line = _line(cf)
        cf_fam = family(cf.get("category", ""))
        best_xi = -1
        best_dist = LINE_WINDOW + 1
        for xi, xf in enumerate(codex):
            if xi in codex_used:
                continue
            if xf.get("file", "") != cf_file:
                continue
            if family(xf.get("category", "")) != cf_fam:
                continue
            dist = abs(_line(xf) - cf_line)
            if dist <= LINE_WINDOW and dist < best_dist:
                best_xi = xi
                best_dist = dist
        if best_xi >= 0:
            consensus_pairs.append((cf, codex[best_xi]))
            claude_used.add(ci)
            codex_used.add(best_xi)
    return consensus_pairs, claude_used, codex_used


def load_findings(path: str) -> list:
    """Load a reviewer's findings; return [] on any parse error.

    Errors are logged to stderr but never fatal — a reviewer that emits
    malformed JSON should not block the whole pass.
    """
    try:
        text = Path(path).read_text()
    except FileNotFoundError:
        print(f"WARN: {path} not found, treating as empty", file=sys.stderr)
        return []
    try:
        data = json.loads(text)
    except json.JSONDecodeError as e:
        print(f"WARN: {path} not valid JSON ({e}); treating as empty", file=sys.stderr)
        return []
    if not isinstance(data, list):
        print(f"WARN: {path} top-level is not a list; treating as empty", file=sys.stderr)
        return []
    out = []
    for entry in data:
        if isinstance(entry, dict) and "severity" in entry and "category" in entry:
            out.append(entry)
    return out


def fingerprint(f: dict) -> str:
    return f"{f.get('file', '')}:{f.get('line', '')}:{f.get('category', '')}"


def merge_pair(c: dict, x: dict) -> dict:
    """Merge two findings with matching fingerprints. Higher severity wins."""
    sev_c = c.get("severity", "low")
    sev_x = x.get("severity", "low")
    sev = max((sev_c, sev_x), key=lambda s: SEV_RANK.get(s, 0))
    merged = dict(c)
    merged["severity"] = sev
    merged["agreed_by"] = ["claude", "codex"]
    merged["claude_severity"] = sev_c
    merged["codex_severity"] = sev_x
    return merged


def load_cross_review(path: str) -> dict:
    """Load a cross-review response file. Returns {fingerprint: verdict_label}.

    Expected shape: a JSON array of {"fingerprint": "...", "verdict": "AGREE-HIGH"
    | "AGREE-MEDIUM" | "AGREE-LOW" | "DISAGREE" | "NEEDS-MORE-CONTEXT", ...}.
    Malformed entries are silently dropped (cross-review failure shouldn't
    block the whole pass; the original solo findings just stay solo).
    """
    if not path:
        return {}
    try:
        data = json.loads(Path(path).read_text())
    except (FileNotFoundError, json.JSONDecodeError) as e:
        print(f"WARN: {path} not loadable ({e}); cross-review ignored",
              file=sys.stderr)
        return {}
    if not isinstance(data, list):
        return {}
    out = {}
    for entry in data:
        if not isinstance(entry, dict):
            continue
        fp = entry.get("fingerprint", "")
        v = entry.get("verdict", "")
        if fp and v in ("AGREE-HIGH", "AGREE-MEDIUM", "AGREE-LOW",
                        "DISAGREE", "NEEDS-MORE-CONTEXT"):
            out[fp] = v
    return out


# Maps a cross-review AGREE-* label to the severity it implies.
CROSS_AGREE_SEV = {
    "AGREE-HIGH": "high",
    "AGREE-MEDIUM": "medium",
    "AGREE-LOW": "low",
}


def apply_cross_review(solo_findings: list, other_responses: dict,
                       other_reviewer: str) -> tuple:
    """Walk solo findings; promote any that the other reviewer AGREE-*'d.

    Returns (promoted_pairs, still_solo). promoted_pairs is a list of
    (finding, agreed_severity) tuples; still_solo retains its original
    severity and agreed_by.
    """
    promoted = []
    still_solo = []
    for f in solo_findings:
        fp = fingerprint(f)
        verdict = other_responses.get(fp, "")
        if verdict in CROSS_AGREE_SEV:
            agreed_sev = CROSS_AGREE_SEV[verdict]
            f2 = dict(f)
            # Always use the cross-reviewer's severity (AGREE-* is authoritative).
            # AGREE-HIGH escalates an original LOW finding to HIGH; AGREE-LOW
            # de-escalates an original HIGH to LOW (both reviewers now agree
            # at the lower bar — the more conservative ship signal).
            original_sev = f.get("severity", "low")
            sev = agreed_sev
            f2["severity"] = sev
            f2["agreed_by"] = sorted({"claude", "codex"})
            f2["claude_severity"] = original_sev if other_reviewer == "codex" \
                else agreed_sev
            f2["codex_severity"] = agreed_sev if other_reviewer == "codex" \
                else original_sev
            f2["cross_review"] = {"by": other_reviewer, "verdict": verdict}
            promoted.append(f2)
        else:
            f2 = dict(f)
            if verdict:
                f2["cross_review"] = {"by": other_reviewer, "verdict": verdict}
            still_solo.append(f2)
    return promoted, still_solo


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--claude", required=True)
    ap.add_argument("--codex", required=True)
    ap.add_argument("--out", required=True)
    ap.add_argument("--base", default="")
    ap.add_argument("--head", default="")
    ap.add_argument("--claude-cross", default="",
                    help="Claude's verdicts on codex's solo findings")
    ap.add_argument("--codex-cross", default="",
                    help="codex's verdicts on Claude's solo findings")
    ap.add_argument("--cross-review-done", action="store_true",
                    help="Mark this verdict as cross-review-final")
    args = ap.parse_args()

    claude = load_findings(args.claude)
    codex = load_findings(args.codex)

    consensus_pairs, claude_used, codex_used = find_consensus(claude, codex)

    # Separate solo findings (still need cross-review or already received it).
    claude_solo = [dict(f) for i, f in enumerate(claude) if i not in claude_used]
    codex_solo = [dict(f) for i, f in enumerate(codex) if i not in codex_used]

    # Apply cross-review responses (if any were provided).
    codex_responses_to_claude = load_cross_review(args.codex_cross)
    claude_responses_to_codex = load_cross_review(args.claude_cross)

    claude_promoted, claude_still_solo = apply_cross_review(
        claude_solo, codex_responses_to_claude, "codex")
    codex_promoted, codex_still_solo = apply_cross_review(
        codex_solo, claude_responses_to_codex, "claude")

    high_consensus: list = []
    high_contested: list = []
    medium: list = []
    low: list = []

    # 1. Fingerprint-matched consensus pairs (first-pass overlap).
    for cf, xf in consensus_pairs:
        merged = merge_pair(cf, xf)
        bucket = {"high": high_consensus, "medium": medium, "low": low}.get(
            merged["severity"], low)
        bucket.append(merged)

    # 2. Cross-review promoted pairs (second-pass overlap via AGREE-*).
    for f in claude_promoted + codex_promoted:
        sev = f.get("severity", "low")
        bucket = {"high": high_consensus, "medium": medium, "low": low}.get(
            sev, low)
        bucket.append(f)

    # 3. Still-solo findings.
    for f in claude_still_solo:
        f["agreed_by"] = ["claude"]
        sev = f.get("severity", "low")
        bucket = {"high": high_contested, "medium": medium, "low": low}.get(
            sev, low)
        bucket.append(f)
    for f in codex_still_solo:
        f["agreed_by"] = ["codex"]
        sev = f.get("severity", "low")
        bucket = {"high": high_contested, "medium": medium, "low": low}.get(
            sev, low)
        bucket.append(f)

    if high_consensus:
        verdict, exit_code = "REJECT", 1
    elif high_contested:
        verdict, exit_code = "CONTESTED", 2
    elif medium or low:
        verdict, exit_code = "PASS-WITH-NOTES", 0
    else:
        verdict, exit_code = "PASS", 0

    # cross_review_required: any reviewer-exclusive finding at severity >= medium
    # would benefit from a second-opinion pass. Lows skip ("not a style
    # committee"). After the second pass (--cross-review-done), the flag is
    # forced to whatever resulted from the second pass (could still be true if
    # disagreement persists, but cross_review_done = true tells downstream
    # there are no more rounds to run).
    remaining_solo_actionable = sum(
        1 for f in claude_still_solo + codex_still_solo
        if f.get("severity") in ("high", "medium"))
    cross_review_required = remaining_solo_actionable > 0
    cross_review_done = bool(args.cross_review_done)

    out = {
        "verdict": verdict,
        "base": args.base,
        "head": args.head,
        "reviewers": ["claude", "codex"],
        "cross_review_required": cross_review_required,
        "cross_review_done": cross_review_done,
        "totals": {
            "high_consensus": len(high_consensus),
            "high_contested": len(high_contested),
            "medium": len(medium),
            "low": len(low),
        },
        "high_consensus": high_consensus,
        "high_contested": high_contested,
        "medium": medium,
        "low": low,
        "auto_applied": [],
        "user_held": [],
        "reported_only": [],
        "exit_code": exit_code,
    }

    Path(args.out).write_text(json.dumps(out, indent=2))
    # PRELIMINARY suffix on first-pass when cross-review is required but not
    # yet done — strong cognitive signal to the orchestrator (in any session,
    # not just this one) that the verdict is not final. After --cross-review-done
    # the suffix drops. Combined with the Step 5/6 hard gate, this is the
    # cross-session enforcement layer that prevents "skipped Step 4" silent ships.
    if cross_review_required and not cross_review_done:
        print(f"{verdict}-PRELIMINARY")
    else:
        print(verdict)
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
