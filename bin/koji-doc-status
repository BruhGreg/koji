#!/usr/bin/env bash
# koji-doc-status — report drift status for docs tagged with YAML `covers:` frontmatter.
#
# Shared helper for /kick-off (step 2c) and /inspect-doc-drift.
# Parses a doc's frontmatter, checks whether covered paths still exist,
# and counts commits in those paths since the doc's last edit.
#
# Usage:
#   koji-doc-status --scan-tagged           # all repo docs with a `covers:` key
#   koji-doc-status --load-on-kickoff       # bullets from ## Load on Kick-Off
#   koji-doc-status <path> [<path> ...]     # specific docs (repo-root relative or absolute)
#
# Output — one tab-separated record per doc:
#   <path>\t<status>\t<drift>\t<last_commit>\t<covers>\t<missing>
#
#     status      : fresh | stale | orphan | exempt | untagged | missing | malformed
#     drift       : integer commit count in covered paths since the doc's
#                   last edit, or "-" if N/A
#     last_commit : short hash of the doc's last edit, or "-"
#     covers      : space-separated list of covered paths, "none" (sentinel),
#                   or "-"
#     missing     : space-separated list of covered paths that no longer
#                   exist in the working tree, or "-"
#
# The `covers: none` sentinel marks a doc as intentionally untagged — i.e.,
# the doc is narrative/ops/process content that doesn't map to specific code.
# Such docs are omitted from drift reports and from untagged-tagging prompts.
#
# Requires koji-detect to have been sourced (uses $PROJECT_ROOT, $DOCS_PATH).
# Self-sources if those variables are unset.

set -euo pipefail

if [ -z "${PROJECT_ROOT:-}" ] || [ -z "${DOCS_PATH:-}" ]; then
  eval "$(~/.claude/skills/koji/bin/koji-detect)"
fi

KOJI_YAML="$PROJECT_ROOT/.koji.yaml"

STALE_THRESHOLD=$(awk '
  /^docs:[[:space:]]*(#.*)?$/ { in_docs=1; next }
  /^[^[:space:]]/ && !/^docs:/ { in_docs=0 }
  in_docs && /^[[:space:]]+stale_threshold[[:space:]]*:/ {
    sub(/^[[:space:]]+stale_threshold[[:space:]]*:[[:space:]]*/, "")
    sub(/[[:space:]]+#.*$/, "")
    sub(/[[:space:]]*$/, "")
    # Strip surrounding quotes (YAML allows `stale_threshold: "10"`)
    n = length($0)
    if (n >= 2) {
      f = substr($0, 1, 1); l = substr($0, n, 1)
      if ((f == "\"" && l == "\"") || (f == "\047" && l == "\047")) $0 = substr($0, 2, n - 2)
    }
    print; exit
  }
' "$KOJI_YAML" 2>/dev/null | grep -E '^[0-9]+$' || true)
[ -n "${STALE_THRESHOLD:-}" ] || STALE_THRESHOLD=10

# --- frontmatter primitives ---

# Does the doc have a top-level `covers:` key in YAML frontmatter?
has_covers_key() {
  awk '
    { sub(/\r$/, "") }   # CRLF compat: strip trailing CR before pattern checks
    NR==1 { if ($0 != "---") exit 1; in_fm=1; next }
    in_fm && /^---[[:space:]]*$/ { exit 1 }
    in_fm && /^covers[[:space:]]*:/ { found=1; exit 0 }
    END { if (!found) exit 1 }
  ' "$1" 2>/dev/null
}

# Print one path per line from the doc's `covers:` YAML list.
# Emits nothing for empty (`covers: []`, bare `covers:`) or scalar values.
parse_covers() {
  awk '
    { sub(/\r$/, "") }   # CRLF compat
    NR==1 { if ($0 != "---") exit 0; in_fm=1; next }
    in_fm && /^---[[:space:]]*$/ { exit 0 }
    in_fm && /^covers[[:space:]]*:/ {
      in_covers=1
      # Empty inline list: covers: []
      if (match($0, /^covers[[:space:]]*:[[:space:]]*\[[[:space:]]*\][[:space:]]*$/)) exit 0
      # Non-empty inline list: covers: [a, b, "c"]
      if (match($0, /^covers[[:space:]]*:[[:space:]]*\[.*\][[:space:]]*$/)) {
        inner = $0
        sub(/^covers[[:space:]]*:[[:space:]]*\[/, "", inner)
        sub(/\][[:space:]]*$/, "", inner)
        n = split(inner, items, /,/)
        for (i = 1; i <= n; i++) {
          it = items[i]
          sub(/^[[:space:]]+/, "", it)
          sub(/[[:space:]]+$/, "", it)
          if (length(it) >= 2) {
            f = substr(it, 1, 1); l = substr(it, length(it), 1)
            if ((f == "\"" && l == "\"") || (f == "\047" && l == "\047")) it = substr(it, 2, length(it) - 2)
          }
          if (length(it) > 0) print it
        }
        exit 0
      }
      next
    }
    in_fm && in_covers {
      if (match($0, /^[[:space:]]*-[[:space:]]+/)) {
        item = substr($0, RLENGTH + 1)
        sub(/[[:space:]]+#.*$/, "", item)
        sub(/[[:space:]]*$/, "", item)
        if (length(item) >= 2) {
          f = substr(item,1,1); l = substr(item,length(item),1)
          if (f == "\"" && l == "\"") item = substr(item,2,length(item)-2)
          else if (f == "\047" && l == "\047") item = substr(item,2,length(item)-2)
        }
        if (length(item) > 0) print item
        next
      }
      if (match($0, /^[^[:space:]]/)) in_covers = 0
    }
  ' "$1" 2>/dev/null || true
}

# Is the `covers:` line in the YAML frontmatter a legal-but-empty form?
# Matches: "covers:", "covers: ", "covers: []", "covers: [ ]" — frontmatter only.
# Body lines that look like the empty form (e.g., in code examples) are ignored.
is_empty_covers_form() {
  awk '
    BEGIN { fail = 1 }
    { sub(/\r$/, "") }   # CRLF compat
    NR==1 { if ($0 != "---") exit fail; in_fm=1; next }
    in_fm && /^---[[:space:]]*$/ { exit fail }
    in_fm && /^covers[[:space:]]*:[[:space:]]*(\[[[:space:]]*\])?[[:space:]]*(#.*)?$/ { fail = 0; exit fail }
    END { exit fail }
  ' "$1" 2>/dev/null
}

# Is the frontmatter `covers:` value the intentional-untagged sentinel `covers: none`?
# Case-insensitive. Accepts quoted (`"none"`, `'none'`) and trailing-comment forms.
# Frontmatter only — body lines that look like the sentinel (e.g., in code examples) are ignored.
is_covers_none() {
  awk '
    BEGIN { fail = 1 }
    { sub(/\r$/, "") }   # CRLF compat
    NR==1 { if ($0 != "---") exit fail; in_fm=1; next }
    in_fm && /^---[[:space:]]*$/ { exit fail }
    in_fm && /^covers[[:space:]]*:[[:space:]]*/ {
      val = $0
      sub(/^covers[[:space:]]*:[[:space:]]*/, "", val)
      sub(/[[:space:]]*#.*$/, "", val)
      sub(/[[:space:]]*$/, "", val)
      n = length(val)
      if (n >= 2) {
        f = substr(val, 1, 1)
        l = substr(val, n, 1)
        if ((f == "\"" && l == "\"") || (f == "\047" && l == "\047")) val = substr(val, 2, n - 2)
      }
      if (tolower(val) == "none") fail = 0
      exit fail
    }
    END { exit fail }
  ' "$1" 2>/dev/null
}

# --- one-doc status ---

compute_status() {
  local abs="$1"
  local rel="${abs#"$PROJECT_ROOT/"}"

  if [ ! -f "$abs" ]; then
    printf '%s\tmissing\t-\t-\t-\t-\n' "$rel"
    return 0
  fi

  if ! has_covers_key "$abs"; then
    printf '%s\tuntagged\t-\t-\t-\t-\n' "$rel"
    return 0
  fi

  if is_covers_none "$abs"; then
    printf '%s\texempt\t0\t-\tnone\t-\n' "$rel"
    return 0
  fi

  local covers_list
  covers_list=$(parse_covers "$abs")

  if [ -z "$covers_list" ]; then
    if is_empty_covers_form "$abs"; then
      printf '%s\tfresh\t0\t-\t-\t-\n' "$rel"
    else
      printf '%s\tmalformed\t-\t-\t-\t-\n' "$rel"
    fi
    return 0
  fi

  local covers_field
  covers_field=$(printf '%s\n' "$covers_list" | tr '\n' ' ' | sed 's/[[:space:]]*$//')

  local missing=""
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    if [ ! -e "$PROJECT_ROOT/$p" ]; then
      missing="${missing:+$missing }$p"
    fi
  done <<< "$covers_list"

  local full_hash short_hash
  full_hash=$(cd "$PROJECT_ROOT" && git log -1 --format=%H -- "$rel" 2>/dev/null || true)
  short_hash=$(cd "$PROJECT_ROOT" && git log -1 --format=%h -- "$rel" 2>/dev/null || true)
  [ -n "${short_hash:-}" ] || short_hash="-"

  local drift=0
  if [ -n "${full_hash:-}" ]; then
    local covers_args=()
    while IFS= read -r p; do
      [ -n "$p" ] || continue
      covers_args+=("$p")
    done <<< "$covers_list"
    if [ ${#covers_args[@]} -gt 0 ]; then
      drift=$(cd "$PROJECT_ROOT" && git log --oneline "$full_hash..HEAD" -- "${covers_args[@]}" 2>/dev/null | wc -l | tr -d ' ')
    fi
  fi

  local status
  if [ -n "$missing" ]; then
    status="orphan"
  elif [ "$drift" -gt "$STALE_THRESHOLD" ]; then
    status="stale"
  else
    status="fresh"
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$rel" \
    "$status" \
    "$drift" \
    "$short_hash" \
    "$covers_field" \
    "${missing:--}"
}

# --- Load-on-Kick-Off helpers ---

# List bullet bodies (with leading "- "/"* " stripped) from the ## Load on Kick-Off section.
list_loko_bullets() {
  local session="$DOCS_PATH/agent-session.md"
  [ -f "$session" ] || return 0
  awk '
    /^## Load on Kick-Off[[:space:]]*$/ { in_section=1; next }
    in_section && /^## / { exit }
    in_section && /^[[:space:]]*[-*][[:space:]]+/ {
      line = $0
      sub(/^[[:space:]]*[-*][[:space:]]+/, "", line)
      print line
    }
  ' "$session"
}

# Extract `.md` paths from LOKO bullets on stdin. Skips URLs and non-.md lines.
# Output is project-root relative (leading "/" stripped).
# Handles markdown-link anchor/query/title variants: `[doc](foo.md)`,
# `[doc](foo.md#section)`, `[doc](foo.md?v=1)`, `[doc](foo.md "title")`.
extract_loko_paths() {
  while IFS= read -r bullet; do
    [ -n "$bullet" ] || continue
    local path=""
    if printf '%s' "$bullet" | grep -qE '\]\([^)]*\.md'; then
      # Capture path up to `.md`; outer `[^)]*` consumes any #anchor / ?query / "title".
      path=$(printf '%s' "$bullet" | sed -nE 's/.*\(([^)#?]*\.md)[^)]*\).*/\1/p' | awk 'NR==1{print;exit}')
    else
      path=$(printf '%s' "$bullet" | awk '{print $1}')
    fi
    case "$path" in
      http://*|https://*|mailto:*) continue ;;
    esac
    case "$path" in
      *.md) ;;
      *) continue ;;
    esac
    printf '%s\n' "${path#/}"
  done
}

# --- commit listing helpers ---

# Drop lines whose commit subject matches obvious-noise prefixes.
# Input/output: lines formatted "<hash> <subject> (<age>)".
# Matches conventional-commit types considered low-signal for doc drift.
noise_filter() {
  grep -ivE '^[a-f0-9]+ (typo|chore|deps|lint|fmt|format|bump|style|ci|build|docs|version)(\(|:|[[:space:]])'
}

# Compute the git range for drift commits on a doc (doc's last commit..HEAD).
# Prints the range, or empty if the doc has no git history.
doc_commit_range() {
  local rel="$1"
  local doc_commit
  doc_commit=$(cd "$PROJECT_ROOT" && git log -1 --format=%H -- "$rel" 2>/dev/null || true)
  [ -n "$doc_commit" ] || return
  printf '%s..HEAD' "$doc_commit"
}

# Mode: most recent N commits touching any covered path, noise-filtered.
# Falls back to unfiltered if the filter removes everything.
commits_recent() {
  local abs="$1" limit="$2"
  local rel="${abs#"$PROJECT_ROOT/"}"
  local range
  range=$(doc_commit_range "$rel")
  [ -n "$range" ] || return

  local paths_args=()
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    paths_args+=("$p")
  done <<< "$(parse_covers "$abs")"
  [ ${#paths_args[@]} -gt 0 ] || return

  local raw filtered
  raw=$(cd "$PROJECT_ROOT" && git log --format='%h %s (%cr)' "$range" -- "${paths_args[@]}" 2>/dev/null || true)
  [ -n "$raw" ] || return
  filtered=$(printf '%s\n' "$raw" | noise_filter || true)
  [ -n "$filtered" ] || filtered="$raw"
  printf '%s\n' "$filtered" | awk -v n="$limit" 'NR>n{exit} 1'
}

# Mode: top N commits ranked by (files_changed * (insertions + deletions)).
# Favors structural changes over formatting passes. Uses ASCII Unit Separator
# (\x1f) between fields so commit subjects containing `|` (or any printable
# character) parse correctly.
commits_by_size() {
  local abs="$1" limit="$2"
  local rel="${abs#"$PROJECT_ROOT/"}"
  local range
  range=$(doc_commit_range "$rel")
  [ -n "$range" ] || return

  local paths_args=()
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    paths_args+=("$p")
  done <<< "$(parse_covers "$abs")"
  [ ${#paths_args[@]} -gt 0 ] || return

  cd "$PROJECT_ROOT" && git log --format=$'__C\x1f%h\x1f%s\x1f%cr' --shortstat "$range" -- "${paths_args[@]}" 2>/dev/null |
    awk -F $'\x1f' '
      /^__C\x1f/ {
        if (have) { printf "%d\t%s %s (%s)\n", score, hash, subject, age }
        hash = $2; subject = $3; age = $4; score = 0; have = 1
        next
      }
      /files? changed/ {
        files = 0; ins = 0; del = 0
        if (match($0, /[0-9]+ files? changed/)) {
          n = substr($0, RSTART, RLENGTH); sub(/ .*/, "", n); files = n + 0
        }
        if (match($0, /[0-9]+ insertions?/)) {
          n = substr($0, RSTART, RLENGTH); sub(/ .*/, "", n); ins = n + 0
        }
        if (match($0, /[0-9]+ deletions?/)) {
          n = substr($0, RSTART, RLENGTH); sub(/ .*/, "", n); del = n + 0
        }
        score = files * (ins + del)
      }
      END { if (have) printf "%d\t%s %s (%s)\n", score, hash, subject, age }
    ' | sort -rn | awk -v n="$limit" 'NR>n{exit} 1' | cut -f2-
}

# Mode: up to N commits total, round-robin across each covered path.
# Ensures every covered path gets representation even if one is much hotter.
# Tempfiles are cleaned up via RETURN trap — safe against mid-function failure.
commits_per_path() {
  local abs="$1" limit="$2"
  local rel="${abs#"$PROJECT_ROOT/"}"
  local range
  range=$(doc_commit_range "$rel")
  [ -n "$range" ] || return

  local tmpfiles=()
  trap 'if [ ${#tmpfiles[@]} -gt 0 ]; then rm -f "${tmpfiles[@]}"; fi; trap - RETURN' RETURN

  while IFS= read -r p; do
    [ -n "$p" ] || continue
    local tf
    tf=$(mktemp)
    (cd "$PROJECT_ROOT" && git log --format='%h %s (%cr)' "$range" -- "$p" 2>/dev/null) > "$tf" || true
    tmpfiles+=("$tf")
  done <<< "$(parse_covers "$abs")"
  [ ${#tmpfiles[@]} -gt 0 ] || return

  local emitted=0 round=1 any line
  while [ "$emitted" -lt "$limit" ]; do
    any=0
    for tf in "${tmpfiles[@]}"; do
      line=$(sed -n "${round}p" "$tf")
      if [ -n "$line" ]; then
        printf '%s\n' "$line"
        emitted=$((emitted + 1))
        any=1
        [ "$emitted" -ge "$limit" ] && break
      fi
    done
    [ "$any" -eq 0 ] && break
    round=$((round + 1))
  done
}

# --- LOKO history (presence + session-mention age) ---

# Extract LOKO bullet bodies from a piece of agent-session.md content piped on stdin.
list_loko_bullets_from_stdin() {
  awk '
    /^## Load on Kick-Off[[:space:]]*$/ { in_section=1; next }
    in_section && /^## / { exit }
    in_section && /^[[:space:]]*[-*][[:space:]]+/ {
      line = $0
      sub(/^[[:space:]]*[-*][[:space:]]+/, "", line)
      print line
    }
  '
}

# Extract concatenated bodies of every ## Session: entry across BOTH the active
# log AND archive files. Pre-check 2 (session-mention staleness) needs this
# wider view because with default archive.keep=1, the active log holds at most
# 1 session post-rotation — mentions from archived sessions would be invisible.
_session_bodies_from_file() {
  local file="$1"
  [ -f "$file" ] || return 0
  awk '
    /^## Session:/ { in_session=1; next }
    in_session && /^## / && !/^## Session:/ { in_session=0 }
    in_session { print }
  ' "$file" 2>/dev/null
}

extract_session_bodies() {
  local session="$1"
  _session_bodies_from_file "$session"
  local archive_dir="$DOCS_PATH/$ARCHIVE_DIR"
  [ -d "$archive_dir" ] || return 0
  find "$archive_dir" -type f -name '*.md' ! -name 'INDEX.md' 2>/dev/null | while IFS= read -r f; do
    _session_bodies_from_file "$f"
  done
}

# Count total ## Session: entries across active log AND archive files.
# Used by wrap step 2c Pre-check 2's "skip if < 2 entries" gate. Active-only
# count would die under default archive.keep=1.
count_total_sessions() {
  local session="$1"
  local count=0
  [ -f "$session" ] && count=$(awk '/^## Session:/{c++} END{print c+0}' "$session" 2>/dev/null)
  local archive_dir="$DOCS_PATH/$ARCHIVE_DIR"
  if [ -d "$archive_dir" ]; then
    local arch_count
    arch_count=$(find "$archive_dir" -type f -name '*.md' ! -name 'INDEX.md' -exec grep -c '^## Session:' {} \; 2>/dev/null \
      | awk '{s+=$1} END{print s+0}')
    count=$((count + arch_count))
  fi
  echo "$count"
}

# Emit one row per current LOKO bullet:
#   <path>\t<presence>\t<mentioned>\t<commits_since_add>
#
# presence:
#   new        = path is in the working-tree LOKO but not in HEAD's committed
#                version (uncommitted add, e.g. mid-wrap), OR file has no git
#                history at all.
#   recent     = present in HEAD; commits_since_add == 1.
#   established = commits_since_add >= 2.
#
# mentioned:
#   yes = path or basename appears in any ## Session: body across the active
#         log AND archive files.
#   no  = absent from every session body (active + archive).
#
# commits_since_add:
#   integer count of commits to agent-session.md since the bullet was first
#   introduced. -1 if the bullet appears in no committed version.
loko_history() {
  local session_file="$DOCS_PATH/agent-session.md"
  local session_file_rel="${session_file#$PROJECT_ROOT/}"
  [ -f "$session_file" ] || return 0

  local loko_paths
  loko_paths=$(list_loko_bullets | extract_loko_paths | awk '!seen[$0]++')
  [ -n "$loko_paths" ] || return 0

  # Stash session bodies (active + archives) in a temp file. We grep against
  # the FILE in the per-bullet loop, not via `printf "$var" | grep -qF`.
  # Reason: `extract_session_bodies` can emit hundreds of KB once archives are
  # included. With pipefail enabled, `grep -qF` exits early on a match → printf
  # gets SIGPIPE → pipe returns 141 → the `if` reads it as false → `mentioned`
  # was always reported as `no` regardless of whether the path was present.
  local active_bodies_file
  active_bodies_file=$(mktemp)
  extract_session_bodies "$session_file" > "$active_bodies_file"

  # Walk commits oldest-first; for each commit, snapshot LOKO paths.
  # First time a path appears = its add-commit. Cache the add-commit per path.
  local commits
  commits=$(cd "$PROJECT_ROOT" && git log --reverse --format=%H -- "$session_file" 2>/dev/null || true)

  # Use a temp file as a path → first-seen-commit map (bash 3.2 has no assoc arrays).
  local first_seen_file
  first_seen_file=$(mktemp)
  trap 'rm -f "$first_seen_file" "$active_bodies_file"' RETURN

  if [ -n "$commits" ]; then
    while IFS= read -r commit; do
      [ -n "$commit" ] || continue
      local snapshot_loko
      snapshot_loko=$(cd "$PROJECT_ROOT" && { git show "$commit:$session_file_rel" 2>/dev/null \
        | list_loko_bullets_from_stdin \
        | extract_loko_paths \
        | awk '!seen[$0]++'; } || true)
      [ -n "$snapshot_loko" ] || continue
      while IFS= read -r snap_p; do
        [ -n "$snap_p" ] || continue
        # Escape regex metachars in the path before grepping the tempfile,
        # so paths containing `.` `[` `*` etc. match literally.
        # Tab-separator (not space) so paths containing spaces survive
        # round-trip through the path→commit map. The duplicate check uses
        # grep -F with an explicit tab so escaping regex metas in $snap_p
        # is no longer needed.
        if ! grep -qF -- "$(printf '%s\t' "$snap_p")" "$first_seen_file" 2>/dev/null; then
          printf '%s\t%s\n' "$snap_p" "$commit" >> "$first_seen_file"
        fi
      done <<< "$snapshot_loko"
    done <<< "$commits"
  fi

  while IFS= read -r p; do
    [ -n "$p" ] || continue

    # mentioned: literal path OR basename appearing as a WHOLE WORD in a
    # session body (active log + archive files; see extract_session_bodies
    # above). Word-boundary matching (-w) prevents false positives like
    # `customapi.md` matching a LOKO bullet for `notes/api.md`.
    local mentioned=no
    local fname
    fname=$(basename "$p")
    if [ -s "$active_bodies_file" ]; then
      if grep -wqF "$p" "$active_bodies_file" 2>/dev/null; then
        mentioned=yes
      elif grep -wqF "$fname" "$active_bodies_file" 2>/dev/null; then
        mentioned=yes
      fi
    fi

    # commits_since_add: look up first-seen commit, count commits since
    local add_commit=""
    add_commit=$(awk -F'\t' -v p="$p" '$1 == p { print $2; exit }' "$first_seen_file" 2>/dev/null || true)

    local commits_since_add=-1
    if [ -n "$add_commit" ]; then
      commits_since_add=$(cd "$PROJECT_ROOT" && git rev-list --count "$add_commit..HEAD" -- "$session_file" 2>/dev/null || echo -1)
      # rev-list excludes the add-commit itself; bump by 1 so a bullet present
      # only in HEAD's most recent commit reads as commits_since_add=1 (recent).
      if [ "$commits_since_add" != "-1" ]; then
        commits_since_add=$((commits_since_add + 1))
      fi
    fi

    local presence
    case "$commits_since_add" in
      -1|0) presence=new ;;
      1)    presence=recent ;;
      *)    presence=established ;;
    esac

    printf '%s\t%s\t%s\t%s\n' "$p" "$presence" "$mentioned" "$commits_since_add"
  done <<< "$loko_paths"
}

# Emit a focus-filtered subset of $DOCS_PATH/lessons.md.
#
# Convention: entries are appended at the top (newest first). An entry begins
# with a YYYY-MM-DD date line and continues until the next date line (or EOF).
# Entries are often multi-line — code blocks, paragraphs, etc.
#
# Scoring: for each entry, count distinct focus-token matches in the entry's
# lowercased text. Tokens come from the --focus argument (space-separated),
# stripped of common stopwords and short tokens (<3 chars), case-insensitive.
#
# Output: union of (a) top 3 most recent entries (always — baseline) and
# (b) entries with score > 0, sorted by score desc, tie-broken by recency.
# Deduplicated, capped at --limit (default 8).
#
# Cold-start (empty/missing --focus): top 10 by recency (matches the pre-v0.5
# kick-off behavior — backwards-compatible fallback).
#
# Light L1 tags (optional): if the date line has a `[domain1,domain2]` block
# between `[Agent]` and `—`, those tokens live in the entry's lowercased text
# like any other content and contribute to scoring naturally.
lessons_relevant() {
  local lessons_file="$DOCS_PATH/lessons.md"
  local focus="$1"
  local limit="${2:-8}"
  [ -f "$lessons_file" ] || return 0

  awk -v focus="$focus" -v limit="$limit" '
    BEGIN {
      stop = "the|and|for|with|that|this|from|into|but|not|when|how|why|where|what|some|any|all|every|each|will|can|should|must|just|only|than|then|else|like|over|under|been|have|has|had|was|were|are|is|be|to|of|in|on|at|by|or|as|if|it|we|us|our|they|them|their|use|using|used|now|new|run|via|per|too|also|see|via|set|get|got|put"
      n = split(tolower(focus), raw, "[[:space:]]+")
      n_tok = 0
      for (i = 1; i <= n; i++) {
        t = raw[i]
        if (length(t) < 3) continue
        if (t ~ "^("stop")$") continue
        dup = 0
        for (k = 1; k <= n_tok; k++) if (tokens[k] == t) { dup = 1; break }
        if (!dup) tokens[++n_tok] = t
      }
      ne = 0
      current = ""
      current_lc = ""
    }

    # Track fenced-code state — a line starting with ``` toggles it. The
    # fence line itself still becomes part of the current entry (handled by
    # the catch-all rule below); we just need to suppress date-line detection
    # while inside a fence so a code-block log timestamp does not get treated
    # as a new lesson header.
    {
      if ($0 ~ /^```/) in_fence = !in_fence
    }

    !in_fence && /^[0-9]{4}-[0-9]{2}-[0-9]{2}/ {
      if (ne > 0 && current != "") {
        entries[ne] = current
        lcs[ne] = current_lc
      }
      ne++
      current = $0
      current_lc = tolower($0)
      next
    }

    {
      if (ne > 0) {
        current = current "\n" $0
        current_lc = current_lc "\n" tolower($0)
      }
    }

    END {
      if (ne > 0 && current != "") {
        entries[ne] = current
        lcs[ne] = current_lc
      }

      # Cold-start fallback: no focus tokens → top 10 most recent
      if (n_tok == 0) {
        cap = 10
        if (limit + 0 > 0 && limit + 0 < cap) cap = limit + 0
        for (i = 1; i <= ne && i <= cap; i++) {
          print entries[i]
          print ""
        }
        exit
      }

      # Score each entry
      for (i = 1; i <= ne; i++) {
        s = 0
        for (k = 1; k <= n_tok; k++) {
          if (index(lcs[i], tokens[k]) > 0) s++
        }
        scores[i] = s
      }

      out = 0
      max_out = limit + 0
      if (max_out <= 0) max_out = 8

      # Phase 1: top 3 most recent as baseline (always)
      for (i = 1; i <= ne && out < 3 && out < max_out; i++) {
        if (!(i in seen)) {
          print entries[i]
          print ""
          seen[i] = 1
          out++
        }
      }

      # Phase 2: matched entries sorted by score desc, tie-break recency desc (smaller index = newer)
      n_match = 0
      for (i = 1; i <= ne; i++) {
        if (scores[i] > 0 && !(i in seen)) matches[++n_match] = i
      }
      # Bubble sort by score desc, recency desc (index asc as tie-break)
      for (i = 1; i <= n_match; i++) {
        for (j = i + 1; j <= n_match; j++) {
          if (scores[matches[j]] > scores[matches[i]] || \
              (scores[matches[j]] == scores[matches[i]] && matches[j] < matches[i])) {
            t = matches[i]; matches[i] = matches[j]; matches[j] = t
          }
        }
      }
      for (k = 1; k <= n_match && out < max_out; k++) {
        print entries[matches[k]]
        print ""
        out++
      }
    }
  ' "$lessons_file"
}

# --- dispatch ---

case "${1:-}" in
  --scan-tagged)
    cd "$PROJECT_ROOT"
    DOCS=$(git grep -l -E '^[[:space:]]*covers[[:space:]]*:' -- '*.md' 2>/dev/null | sort -u || true)
    if [ -n "$DOCS" ]; then
      while IFS= read -r rel; do
        [ -n "$rel" ] || continue
        if has_covers_key "$PROJECT_ROOT/$rel"; then
          compute_status "$PROJECT_ROOT/$rel"
        fi
      done <<< "$DOCS"
    fi
    ;;
  --load-on-kickoff|--loko)
    (list_loko_bullets | extract_loko_paths || true) | while IFS= read -r rel; do
      [ -n "$rel" ] || continue
      compute_status "$PROJECT_ROOT/$rel"
    done
    ;;
  --loko-history)
    loko_history
    ;;
  --count-sessions)
    count_total_sessions "$DOCS_PATH/agent-session.md"
    ;;
  --lessons-relevant)
    shift
    lr_focus=""
    lr_limit=8
    while [ $# -gt 0 ]; do
      case "$1" in
        --focus) lr_focus="${2:-}"; shift 2 ;;
        --limit) lr_limit="${2:-8}"; shift 2 ;;
        --) shift; break ;;
        *) shift ;;
      esac
    done
    lessons_relevant "$lr_focus" "$lr_limit"
    ;;
  --commits)
    shift
    commits_mode=recent
    commits_limit=3
    commits_path=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --limit)
          if [ $# -ge 2 ]; then
            commits_limit="$2"
            shift 2
          else
            shift
          fi
          ;;
        --by-size)  commits_mode=by-size; shift ;;
        --per-path) commits_mode=per-path; shift ;;
        --*)        shift ;;
        *)          commits_path="$1"; shift ;;
      esac
    done
    [ -n "$commits_path" ] || exit 1
    case "$commits_path" in
      /*) commits_abs="$commits_path" ;;
      *)  commits_abs="$PROJECT_ROOT/$commits_path" ;;
    esac
    [ -f "$commits_abs" ] || exit 0
    case "$commits_mode" in
      recent)   commits_recent   "$commits_abs" "$commits_limit" ;;
      by-size)  commits_by_size  "$commits_abs" "$commits_limit" ;;
      per-path) commits_per_path "$commits_abs" "$commits_limit" ;;
    esac
    ;;
  --help|-h|"")
    cat <<'USAGE'
koji-doc-status — drift status for docs tagged with YAML `covers:` frontmatter.

Usage:
  koji-doc-status --scan-tagged          # all repo docs with a `covers:` key
  koji-doc-status --load-on-kickoff      # bullets from ## Load on Kick-Off
  koji-doc-status --loko-history         # presence + session-mention age per
                                         # bullet (used by /wrap Pass C)
  koji-doc-status <path> [<path> ...]    # specific doc paths

  koji-doc-status --commits <path> [--limit N] [--by-size|--per-path]
                                         # list commits in covered paths since
                                         # the doc's last edit
    --limit N    max commits to emit (default 3)
    --by-size    rank by files_changed × (insertions+deletions)
    --per-path   round-robin across each covered path
    (default)    most recent, with noise-prefix filter

Output (tab-separated, one record per doc — status modes):
  <path>\t<status>\t<drift>\t<last_commit>\t<covers>\t<missing>
  status: fresh | stale | orphan | exempt | untagged | missing | malformed

  `exempt` means the doc declared `covers: none` — intentionally untagged.

Output (--loko-history mode, one record per current LOKO bullet):
  <path>\t<presence>\t<mentioned>\t<commits_since_add>
  presence:  new | recent | established
    new        — uncommitted add OR file has no git history
    recent     — present in HEAD; commits_since_add == 1
    established — commits_since_add >= 2 (≥ 2 wraps in LOKO)
  mentioned: yes | no
    yes — path or basename appears in any active-log ## Session: body
    no  — absent from every active-log session body

Output (commit mode):
  <short-hash> <subject> (<relative-age>)
USAGE
    ;;
  *)
    for p in "$@"; do
      case "$p" in
        /*) compute_status "$p" ;;
        *) compute_status "$PROJECT_ROOT/$p" ;;
      esac
    done
    ;;
esac
