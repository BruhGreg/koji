#!/usr/bin/env python3
"""koji-duet-impl-parse: split a /duet-plan locked plan into ordered segments
delimited by <!-- gate: NAME --> markers.

Output: JSON array of segments. Each segment has:
  - gate:   gate name (from marker) or "FINAL" for content after the last
            marker (or the whole plan when no markers exist)
  - text:   markdown text of this segment
  - is_last: true on the last segment, false otherwise

Empty segments (marker at start, two markers back-to-back) are skipped.

`/duet-impl` runs codex single-review at every gate marker, then runs
`/duet-review` (2-reviewer pass) on the full diff at the end of the run.
The parser does NOT mark which segment triggers /duet-review — that's an
end-of-run step orchestrated by SKILL.md, independent of the parsed gates.
"""
import argparse
import json
import re
import sys
from pathlib import Path

GATE_RE = re.compile(r"^\s*<!--\s*gate:\s*(\S+)\s*-->\s*$", re.MULTILINE)


def parse_segments(plan_text: str) -> list:
    segments = []
    last_end = 0
    for m in GATE_RE.finditer(plan_text):
        gate_name = m.group(1)
        text = plan_text[last_end:m.start()].rstrip()
        if text.strip():
            segments.append({"gate": gate_name, "text": text})
        last_end = m.end()
    final_text = plan_text[last_end:].strip()
    if final_text:
        segments.append({"gate": "FINAL", "text": final_text})
    if segments:
        for s in segments:
            s["is_last"] = False
        segments[-1]["is_last"] = True
    return segments


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--plan", required=True, help="path to locked plan file")
    ap.add_argument(
        "--summary",
        action="store_true",
        help="print a one-line summary (gate count, names) instead of full JSON",
    )
    args = ap.parse_args()

    plan_file = Path(args.plan)
    if not plan_file.is_file():
        print(f"ERROR: plan file not found: {plan_file}", file=sys.stderr)
        return 1

    segments = parse_segments(plan_file.read_text())
    if args.summary:
        gate_names = [s["gate"] for s in segments]
        print(f"{len(segments)} segments: {' → '.join(gate_names)}")
    else:
        print(json.dumps(segments, indent=2))
    return 0


if __name__ == "__main__":
    sys.exit(main())
