#!/usr/bin/env bash
# koji-config — read/write ~/.koji/config.yaml
#
# Usage:
#   koji-config get <key>          — read a config value
#   koji-config set <key> <value>  — write a config value
#   koji-config list               — show all config
#
# Env overrides (for testing):
#   KOJI_STATE_DIR  — override ~/.koji state directory
set -euo pipefail

STATE_DIR="${KOJI_STATE_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/koji}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: koji-config get <key>}"
    if ! printf '%s' "$KEY" | grep -qE '^[a-zA-Z0-9_]+$'; then
      echo "Error: key must contain only alphanumeric characters and underscores" >&2
      exit 1
    fi
    grep -F "${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: koji-config set <key> <value>}"
    VALUE="${3:?Usage: koji-config set <key> <value>}"
    if ! printf '%s' "$KEY" | grep -qE '^[a-zA-Z0-9_]+$'; then
      echo "Error: key must contain only alphanumeric characters and underscores" >&2
      exit 1
    fi
    mkdir -p "$STATE_DIR"
    ESC_VALUE="$(printf '%s' "$VALUE" | head -1 | sed 's/[&/\]/\\&/g')"
    if grep -qF "${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      _tmpfile="$(mktemp "${CONFIG_FILE}.XXXXXX")"
      sed "s/^${KEY}:.*/${KEY}: ${ESC_VALUE}/" "$CONFIG_FILE" > "$_tmpfile" && mv "$_tmpfile" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: koji-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
